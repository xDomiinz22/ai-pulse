# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/aipulse?schema=public"

# Secret for signing JWTs. MUST be >= 32 random chars and not a placeholder.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="secreto_largo_y_aleatorio_min_32_chars"

# How long issued tokens stay valid (zeit/ms format). Keep it short.
JWT_EXPIRES_IN="1d"

# Server port and allowed frontend origin (CORS).
PORT=3001
FRONTEND_URL="http://localhost:5177"

# Set to "production" in prod to enable HSTS and combined access logs.
NODE_ENV="development"

# Google Gemini API key for the news scraper (https://aistudio.google.com).
GEMINI_API_KEY="your-gemini-api-key"

# Upstash Redis (https://console.upstash.com) — HTTP-based, works on Vercel.
# Optional: if unset, the app runs without cache/rate-limit/trending features.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
